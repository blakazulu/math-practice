# Node
node_modules/
.npm/

# Build outputs
dist/
.vite/
*.tsbuildinfo

# Avoid committing tsc emit alongside src (Vite is the bundler)
src/**/*.js
src/**/*.d.ts
tests/**/*.js
tests/**/*.d.ts
!src/vite-env.d.ts

# Vite-scaffold defaults
dist-ssr/
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.sw?

# Brainstorm/visual companion artifacts
.superpowers/

# Test artifacts
coverage/
playwright-report/
test-results/

# Temp
*.tmp
