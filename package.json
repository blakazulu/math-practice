    "dev": "npm run sync-data && vite",
    "build": "npm run generate-pdfs && npm run sync-data && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write src",
    "generate-pdfs": "node tools/pdf/generate_pdfs.mjs",
    "sync-data": "node scripts/sync-data.mjs",
    "gen-share-images": "node scripts/gen-share-images.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "katex": "^0.16.47",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-katex": "^3.1.0",
    "react-router-dom": "^6.30.3",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@fontsource/heebo": "^5.2.8",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.8.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.5.0",
